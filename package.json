{
  "name": "frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm test",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "clean": "node -e \"const{rmSync,existsSync}=require('node:fs');for(const p of ['dist','node_modules/.tmp','node_modules/.vite','node_modules/.cache','storybook-static']){if(existsSync(p)){rmSync(p,{recursive:true,force:true});console.log('removed',p);}}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "@hookform/resolvers": "5.2.2",
    "@tanstack/react-query": "5.100.14",
    "@tanstack/react-router": "1.168.4",
    "@tanstack/react-table": "8.21.3",
    "axios": "1.13.6",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "1.16.0",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-day-picker": "9.14.0",
    "react-dom": "19.2.4",
    "react-error-boundary": "6.1.1",
    "react-hook-form": "7.72.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.2.1",
    "@eslint/js": "9.39.4",
    "@storybook/addon-a11y": "10.4.1",
    "@storybook/addon-themes": "10.4.1",
    "@tailwindcss/vite": "4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-security": "4.0.0",
    "globals": "16.5.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "shadcn": "4.8.2",
    "storybook": "10.4.1",
    "tailwindcss": "4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.57.1",
    "vite": "7.3.1",
    "vite-plugin-checker": "0.12.0",
    "vitest": "4.1.7",
    "eslint-plugin-storybook": "10.4.1",
    "@storybook/tanstack-react": "10.4.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
